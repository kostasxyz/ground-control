{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ground-control",
  "version": "0.1.0",
  "identifier": "com.groundcontrol.taurispike",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GROUND CONTROL",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#1a120c"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost groundcontrol:",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost groundcontrol: blob: data:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
